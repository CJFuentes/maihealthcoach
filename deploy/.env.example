# =============================================================================
# MAI Health Coach - local dev environment variables
#
# Usage (inside deploy/):
#   cp .env.example .env
#   # then edit .env if you want different local credentials
#
# .env is gitignored. .env.example is committed and documents every required
# variable. NEVER put real secrets in this file - local dev defaults only.
# =============================================================================

# -- PostgreSQL ---------------------------------------------------------------
# Used by both the postgres service and the API's ConnectionStrings__Postgres.
POSTGRES_USER=maihc
POSTGRES_PASSWORD=localdevpassword
POSTGRES_DB=maihealthcoach

# The API reads its DB connection from ConnectionStrings__Postgres. The double
# underscore (__) maps to the nested "ConnectionStrings:Postgres" config key.
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=maihealthcoach;Username=maihc;Password=localdevpassword

# -- Clerk (public metadata — NOT secret) -------------------------------------
# Used by future JWT validation (#12). The double underscore maps to the nested
# config keys "Clerk:Authority" etc. Leave blank to run without Clerk wired up.
Clerk__Authority=https://your-clerk-instance.clerk.accounts.dev
Clerk__Issuer=https://your-clerk-instance.clerk.accounts.dev
Clerk__JwksUrl=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
Clerk__Audience=

# -- Claude / Anthropic (Ai__ApiKey is a SERVER-SIDE SECRET) ------------------
# Ai__ApiKey MUST come from a secret store / user-secrets — never commit a real
# key. The value below is a DUMMY placeholder. Model/base-url defaults are
# non-secret and already shipped in appsettings.json.
Ai__ApiKey=sk-ant-DUMMY-DO-NOT-COMMIT-REAL-KEYS
Ai__DefaultModel=claude-sonnet-4-6
Ai__EscalationModel=claude-opus-4-8
Ai__BaseUrl=https://api.anthropic.com
Ai__TimeoutSeconds=100
