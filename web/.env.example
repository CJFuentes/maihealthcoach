# Vite exposes only variables prefixed with VITE_ to the browser bundle.
#
# DEV (default): leave VITE_API_BASE_URL empty (or remove it entirely).
#   Requests to /api/* are forwarded by the Vite dev proxy to http://localhost:5000.
#   No CORS configuration on the backend is needed during local development.
#
# PROD: set this to the absolute backend URL, e.g.:
#   VITE_API_BASE_URL=https://api.maihealthcoach.com
#
VITE_API_BASE_URL=

# Clerk publishable key.
# Obtain it from the Clerk dashboard (https://dashboard.clerk.com).
#
# When unset, the app falls back to a syntactically-valid DUMMY key so that the
# build, tests, and CI run without a real Clerk account or any network call
# (Clerk validates key *format*, not validity, when ClerkProvider mounts).
# Authentication only works once a REAL pk_test_/pk_live_ key is supplied here.
VITE_CLERK_PUBLISHABLE_KEY=
