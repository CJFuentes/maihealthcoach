root = true

# ── Defaults for every file ──────────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

# ── C# ───────────────────────────────────────────────────────────────────────
[*.cs]
indent_style = space
indent_size  = 4

# ── .NET project/solution files ───────────────────────────────────────────────
[*.{csproj,sln,props,targets}]
indent_style = space
indent_size  = 2

# ── TypeScript / JavaScript / React ──────────────────────────────────────────
[*.{ts,tsx,js,jsx}]
indent_style = space
indent_size  = 2

# ── Swift ────────────────────────────────────────────────────────────────────
[*.swift]
indent_style = space
indent_size  = 4

# ── Kotlin ───────────────────────────────────────────────────────────────────
[*.kt]
indent_style = space
indent_size  = 4

[*.kts]
indent_style = space
indent_size  = 4

# ── JSON ─────────────────────────────────────────────────────────────────────
[*.json]
indent_style = space
indent_size  = 2

# ── YAML ─────────────────────────────────────────────────────────────────────
[*.{yaml,yml}]
indent_style = space
indent_size  = 2

# ── Markdown ─────────────────────────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
indent_size              = 2

# ── Shell scripts ─────────────────────────────────────────────────────────────
[*.sh]
indent_style = space
indent_size  = 2

# ── Makefiles require tabs ────────────────────────────────────────────────────
[Makefile]
indent_style = tab
