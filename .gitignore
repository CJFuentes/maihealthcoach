# =============================================================================
# MAI Health Coach — root .gitignore
# Merges: .NET/C#, Node/Vite, Swift/Xcode, Kotlin/Gradle, and tooling patterns
# =============================================================================

# ── OS cruft ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# =============================================================================
# .NET / C#
# =============================================================================
## Build outputs
[Bb]in/
[Oo]bj/
[Oo]ut/
[Ll]og/
[Ll]ogs/

## NuGet
*.nupkg
*.snupkg
.nuget/
packages/
!**/packages/build/
project.lock.json
project.fragment.lock.json
artifacts/

## Visual Studio / Rider
.vs/
*.user
*.suo
*.userprefs
*.userosscache
*.sln.docstates
*.ncb
*.sap
*.pidb
*.cachefile

## Publish / Deploy artifacts
**/publish/
**/PublishProfiles/

## EF Core migrations are source-controlled — do NOT ignore the Migrations folder

## Test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.trx
*.coverage
*.coveragexml

## Secrets — never commit
**/appsettings.Development.json
**/appsettings.Local.json
**/*.pfx
**/*.p12

# =============================================================================
# Node / Vite / React (web/)
# =============================================================================
node_modules/
.npm
.yarn/
.pnp.*
dist/
build/
.cache/
.parcel-cache/
.vite/
*.local

## Env files — keep .env.example, ignore actuals
.env
.env.*
!.env.example

## Lock files (package-lock.json / yarn.lock) are intentionally tracked

# =============================================================================
# Swift / Xcode (ios/)
# =============================================================================
## Build
ios/build/
ios/DerivedData/
ios/*.xcworkspace/xcuserdata/
ios/**/*.xcuserstate
ios/*.xcodeproj/project.xcworkspace/

## SPM — keep Package.resolved for reproducibility
ios/**/*.resolved
!ios/**/Package.resolved

## Xcode generated
ios/*.xcodeproj/xcuserdata/
ios/Pods/
ios/.build/

## Fastlane / provisioning
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots/**/*.png
ios/fastlane/test_output/
ios/**/*.mobileprovision
ios/**/*.certSigningRequest

# =============================================================================
# Kotlin / Android / Gradle (android/)
# =============================================================================
android/.gradle/
android/local.properties
android/build/
android/**/build/
android/**/*.apk
android/**/*.aab
android/**/*.ap_
android/**/*.dex
android/.idea/
android/**/.idea/
android/**/*.iml
android/captures/
android/.externalNativeBuild/
android/**/CMakeFiles/
android/**/cmake_install.cmake
android/**/CMakeCache.txt

## Keystore — NEVER commit signing keys
android/**/*.jks
android/**/*.keystore

# =============================================================================
# Docker / Podman / Deploy (deploy/)
# =============================================================================
deploy/.env
deploy/**/.env
deploy/**/*.env
# keep Containerfile and compose files tracked

# =============================================================================
# Docs tooling
# =============================================================================
docs/_site/
docs/.jekyll-cache/

# =============================================================================
# Secrets catchall — last line of defense
# =============================================================================
*.pem
*.key
*.p8
secrets/
.secrets/
