# =============================================================================
# MAI Health Coach - PRODUCTION environment variable template
#
# This file documents every NON-SECRET production variable. Copy it to the
# absolute path referenced by api.container's EnvironmentFile and fill in real
# values:
#
#   sudo install -m 600 -D deploy/prod/.env.example /etc/maihealthcoach/prod.env
#   sudo $EDITOR /etc/maihealthcoach/prod.env
#
# SECRETS DO NOT GO HERE. The DB connection string (with its password) and the
# Anthropic API key are injected via Podman secrets and are intentionally absent
# from this file - see docs/deployment-runbook.md s3:
#
#   echo -n 'Host=maihealthcoach-postgres;Port=5432;Database=maihealthcoach;Username=maihc;Password=STRONG_DB_PASSWORD' \
#     | podman secret create maihc-connstr -
#   echo -n 'STRONG_DB_PASSWORD'        | podman secret create maihc-postgres-password -
#   echo -n 'sk-ant-REAL-ANTHROPIC-KEY' | podman secret create maihc-ai-api-key -
#
# A real deploy/prod/.env (or any *.env under deploy/) is gitignored. This
# .env.example is the only committed file and must never contain real secrets.
#
# Variables use the ASP.NET Core `__` (double-underscore) convention to map onto
# nested config keys (e.g. Clerk__Authority -> Clerk:Authority).
# =============================================================================

# -- Clerk (public metadata - NOT secret) ------------------------------------
Clerk__Authority=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
Clerk__Issuer=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev
Clerk__JwksUrl=https://YOUR_CLERK_INSTANCE.clerk.accounts.dev/.well-known/jwks.json
Clerk__Audience=

# -- Claude / Anthropic -------------------------------------------------------
# Ai__ApiKey is a SERVER-SIDE SECRET injected via the `maihc-ai-api-key` Podman
# secret - do NOT set it here. Only the non-secret model/base-url defaults belong
# in this file.
Ai__DefaultModel=claude-sonnet-4-6
Ai__EscalationModel=claude-opus-4-8
Ai__BaseUrl=https://api.anthropic.com
Ai__TimeoutSeconds=100

# -- Open Food Facts (non-secret) ---------------------------------------------
# OFF requires a descriptive User-Agent on every request.
OpenFoodFacts__BaseUrl=https://world.openfoodfacts.org
OpenFoodFacts__UserAgent=MAIHealthCoach/1.0 (+https://github.com/CJFuentes/maihealthcoach)
OpenFoodFacts__TimeoutSeconds=15
OpenFoodFacts__CacheTtlDays=30
OpenFoodFacts__SearchPageSize=20

# -- OpenTelemetry (non-secret) -----------------------------------------------
# Set OTEL_EXPORTER_OTLP_ENDPOINT (native OTel var) OR Telemetry__Otlp__Endpoint
# to an absolute http(s):// collector URL to enable OTLP trace/metric export.
# Leave both empty to disable OTLP - the app boots fine without it.
OTEL_EXPORTER_OTLP_ENDPOINT=
Telemetry__Otlp__Endpoint=
# Set to true to expose /metrics for Prometheus scraping (/metrics is exempt from
# rate limiting).
Telemetry__Prometheus__Enabled=false

# -- Rate limiting (non-secret - tune for production load) --------------------
RateLimiting__Enabled=true
RateLimiting__GlobalPermitLimit=100
RateLimiting__GlobalWindowSeconds=60
# Per-user limiter for the coach LLM endpoints (chat / meal-suggestions / nudge).
CoachChat__PermitLimit=10
CoachChat__WindowSeconds=60
CoachChat__MaxMessageLength=4000
CoachChat__HistoryTurnLimit=20

# -- Notes --------------------------------------------------------------------
# ConnectionStrings__Postgres is intentionally NOT here: it is injected as the
# `maihc-connstr` Podman secret (full string incl. password). Its host must be
# the Postgres container name `maihealthcoach-postgres` (NOT localhost) because
# the API reaches Postgres over the shared Podman network.
#
# ASPNETCORE_ENVIRONMENT, ASPNETCORE_HTTP_PORTS and Database__AutoMigrate are set
# directly in api.container (not here) so they cannot be accidentally overridden.
